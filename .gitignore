# =========================
# Dataset (IMPORTANT)
# =========================

# Ignore raw datasets (too big usually)
dataset/raw/

# Ignore intermediate/generated data if needed
dataset/**/full_*.csv

# OPTIONAL: ignore train/test if too big
# (uncomment if needed)
# dataset/**/train.csv
# dataset/**/test.csv

